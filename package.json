{
  "name": "shadow-whisper",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:effect": "node node_modules/@effect/language-service/cli.js diagnostics --project apps/worker/tsconfig.json --severity error,warning --strict --format pretty",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:check": "node scripts/check-i18n.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@effect/language-service": "0.85.1",
    "wrangler": "4.87.0",
    "@eslint/js": "9.39.2",
    "better-sqlite3": "12.10.0",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.8.1",
    "turbo": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
    "es-toolkit": "1.44.0"
  }
}
